{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (NestJS Attach)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "preLaunchTask": "Start Backend (Debug)",
      "presentation": {
        "hidden": true
      }
    },
    {
      "name": "Frontend (Next.js)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/frontend",
      "presentation": {
        "hidden": true
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (F5)",
      "configurations": ["Backend (NestJS Attach)", "Frontend (Next.js)"],
      "stopAll": true,
      "presentation": {
        "order": 1
      }
    }
  ]
}
